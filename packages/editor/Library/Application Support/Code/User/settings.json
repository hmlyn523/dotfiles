{
  "git.autofetch": true,
  "workbench.iconTheme": "vscode-icons",

  // 検索にマッチした箇所をハイライト
  "vim.hlsearch": true,
  // OS のクリップボードと同期
  "vim.useSystemClipboard": true,
  // モードごとにステータスバーの色
  "vim.statusBarColorControl": true,
  "vim.statusBarColors.normal": ["#005f5f", "#fff"],
  "vim.statusBarColors.insert": ["#5f0000", "#fff"],
  "vim.statusBarColors.visual": ["#5f00af", "#fff"],
  "vim.statusBarColors.visualline": ["#005f87", "#fff"],
  "vim.statusBarColors.visualblock": ["#86592d", "#fff"],
  "vim.statusBarColors.replace": ["#000000", "#fff"],
  "vim.statusBarColors.commandlineinprogress": ["#86592d", "#fff"],
  "vim.statusBarColors.searchinprogressmode": ["#86592d", "#fff"],
  "vim.statusBarColors.easymotionmode": ["#86592d", "#fff"],
  "vim.statusBarColors.easymotioninputmode": ["#86592d", "#fff"],
  "vim.statusBarColors.surroundinputmode": ["#86592d", "#fff"],
  "workbench.colorCustomizations": {
    "statusBar.background": "#005f5f",
    "statusBar.noFolderBackground": "#005f5f",
    "statusBar.debuggingBackground": "#005f5f",
    "statusBar.foreground": "#fff",
    "statusBar.debuggingForeground": "#fff"
  },
  "vim.autoSwitchInputMethod.enable": true,
  "vim.autoSwitchInputMethod.defaultIM": "-c",
  "git.ignoreRebaseWarning": true,
  // 差分エディタ (diff editor) での空白の変更を無視しない
  "diffEditor.ignoreTrimWhitespace": false,
  // インデントはスペース2つ
  "editor.tabSize": 2,
  // ファイル保存時にフォーマット
  "editor.formatOnSave": true,
  "workbench.tree.indent": 16,
  "editor.guides.bracketPairs": true,
  "workbench.editor.wrapTabs": true,
  "gitlens.ai.model": "vscode",
  "gitlens.ai.vscode.model": "copilot:gpt-4.1",
  "editor.wordWrap": "on",
  "chat.viewSessions.orientation": "stacked",
  "chat.tools.terminal.autoApprove": {
    "/^setopt errexit && for t in surface_stack_snapshot_reads_app_owned_stack_state_t_surface_031 pane_close_cleans_up_surface_attachment surface_stack_snapshot_projects_single_entry_current_model_t_surface_014 surface_stack_snapshot_projects_parent_and_child_layers_t_surface_017 surface_restore_resolver_prefers_parent_surface_before_editor_t_surface_017 ui_dismiss_active_closes_promoted_contiguous_suffix_in_three_layer_stack_t_surface_020 cancel_observation_aligns_current_future_actual_vocabulary_t_surface_026 dismiss_active_observation_aligns_current_future_actual_vocabulary_t_surface_026 restore_observation_exposes_future_candidates_while_actual_restore_adopts_selected_parent_candidate_t_surface_030 pane_attach_view_cleans_up_surface_stack_state_t_surface_032 pane_attach_resident_cleans_up_previous_surface_stack_state_t_surface_032 surface_dismiss_cleans_up_surface_stack_state_t_surface_032 surface_accept_without_close_preserves_surface_stack_state_t_surface_032; do echo TEST:\\$t; cargo test --lib \"\\$t\" -- --color never; done$/": {
      "approve": true,
      "matchCommandLine": true
    },
    "/^cargo test --lib 2>&1 \\| tail -6$/": {
      "approve": true,
      "matchCommandLine": true
    },
    "/^cargo test --lib 2>&1 \\| grep \"FAILED\" \\| head -20$/": {
      "approve": true,
      "matchCommandLine": true
    },
    "/^cargo test --lib -- multicursor_command_add_next_match_without_pane_t174 multicursor_command_skip_next_match_without_pane_t174 multicursor_command_remove_last_cursor_without_pane_t174 multicursor_command_reset_to_primary_without_pane_t174 2>&1 \\| tail -30$/": {
      "approve": true,
      "matchCommandLine": true
    },
    "/^cargo test --lib 2>&1 \\| grep -E \"t174\\|FAILED\\|passed\\|failed\" \\| head -20$/": {
      "approve": true,
      "matchCommandLine": true
    }
  }
}
