#!/bin/sh

# ===========================================================
# macOS Setup Script
# ===========================================================

# 設定変更中にシステム環境設定が開いていると上書きされる可能性があるため終了させる
osascript -e 'tell application "System Preferences" to quit'

# スクリーンショットの保存先ディレクトリを作成
mkdir -p "${HOME}/screenshots"

###########################################################
# General Settings (UI/UX)
###########################################################
# ダークモードを有効化
defaults write "Apple Global Domain" AppleInterfaceStyle -string Dark
# ウィンドウのリサイズ速度を爆速にする
defaults write NSGlobalDomain NSWindowResizeTime -float 0.001
# 未確認のアプリケーション実行時の警告ダイアログを無効化
defaults write com.apple.LaunchServices LSQuarantine -bool false
# 操作状況に基づいて自動的にSpacesを並べ替えるのを無効化
defaults write com.apple.dock mru-spaces -bool false
# 視覚効果を減らす (アニメーションの簡略化)
defaults write com.apple.Accessibility ReduceMotionEnabled -bool true
defaults write com.apple.universalaccess reduceMotion -bool true

###########################################################
# Keyboard
###########################################################
# キーの長押しによるアクセント記号入力を無効化（キーリピートを優先）
defaults write NSGlobalDomain ApplePressAndHoldEnabled -bool false
# キーリピートの速度を設定 (KeyRepeat: 2が最速, InitialKeyRepeat: 15が最短)
defaults write NSGlobalDomain KeyRepeat -int 2
defaults write NSGlobalDomain InitialKeyRepeat -int 15
# 自動大文字入力を無効化
defaults write NSGlobalDomain NSAutomaticCapitalizationEnabled -bool false
# 自動スペル補正を無効化
defaults write NSGlobalDomain NSAutomaticSpellingCorrectionEnabled -bool false

###########################################################
# Trackpad, Mouse
###########################################################
# タップでクリックを有効化
defaults write com.apple.AppleMultitouchTrackpad Clicking -bool true
defaults write com.apple.driver.AppleBluetoothMultitouch.trackpad Clicking -bool true
defaults write NSGlobalDomain com.apple.mouse.tapBehavior -int 1
defaults -currentHost write NSGlobalDomain com.apple.mouse.tapBehavior -int 1

# 軌跡の速さを調整
defaults write -g com.apple.trackpad.scaling -float 2.5
defaults write -g com.apple.mouse.scaling -float 2.5

# 3本指でのドラッグ（アクセシビリティの設定に近い挙動）
defaults write com.apple.AppleMultitouchTrackpad TrackpadThreeFingerDrag -bool true
defaults write com.apple.driver.AppleBluetoothMultitouch.trackpad TrackpadThreeFingerDrag -bool true

###########################################################
# Finder
###########################################################
# 隠しファイルを常に表示
defaults write com.apple.finder AppleShowAllFiles -bool true
# 全ての拡張子のファイルを表示
defaults write NSGlobalDomain AppleShowAllExtensions -bool true
# ステータスバーを表示
defaults write com.apple.finder ShowStatusBar -bool true
# パスバーを表示
defaults write com.apple.finder ShowPathbar -bool true
# タイトルバーにフルパスを表示
defaults write com.apple.finder _FXShowPosixPathInTitle -bool true
# ゴミ箱を空にする前の警告を無効化
defaults write com.apple.finder WarnOnEmptyTrash -bool false
# カラムビューをデフォルトにする (icnv: アイコン, clmv: カラム, glyv: ギャラリー)
defaults write com.apple.finder FXPreferredViewStyle -string "clmv"
# ネットワークストレージに .DS_Store を作成しない
defaults write com.apple.desktopservices DSDontWriteNetworkStores -bool true
defaults write com.apple.desktopservices DSDontWriteUSBStores -bool true

###########################################################
# Dock
###########################################################
# Dockを右側に配置
defaults write com.apple.dock orientation -string right
# アイコンサイズを小さく設定 (24)
defaults write com.apple.dock tilesize -float 24
# Dockを自動的に隠す
defaults write com.apple.dock autohide -bool true
# Dockが表示されるまでの遅延をゼロにする
defaults write com.apple.dock autohide-delay -float 0
# Dockが隠れる際のアニメーション速度を最速にする
defaults write com.apple.dock autohide-time-modifier -float 0

###########################################################
# Screenshot
###########################################################
# スクリーンショットの保存先を変更
defaults write com.apple.screencapture location -string "${HOME}/screenshots"
# スクリーンショットに影を含めない
defaults write com.apple.screencapture disable-shadow -bool true

###########################################################
# Specific Apps Settings
###########################################################

# Google Chrome: バックキーで戻る設定を無効化（誤操作防止）
defaults write com.google.Chrome AppleEnableSwipeNavigateWithScrolls -bool false

# Google Chrome: プリントダイアログをシステム標準ではなくChrome独自のものに固定（必要なら）
# defaults write com.google.Chrome DisablePrintPreview -bool true

# iTerm2: プロンプトを表示せずに終了する
defaults write com.googlecode.iterm2 PromptOnQuit -bool false

# VS Code: キーリピートが効かない問題の修正（再度念押し）
defaults write com.microsoft.VSCode ApplePressAndHoldEnabled -bool false

###########################################################
# Finalize: Kill affected applications
###########################################################
echo "設定を反映させるためにプロセスを再起動しています..."

for app in "Dock" "Finder" "SystemUIServer" "ControlCenter" "com.apple.screencaptured"; do
    killall "${app}" > /dev/null 2>&1
done

echo "セットアップが完了しました。一部の設定は再ログイン後に有効になります。"