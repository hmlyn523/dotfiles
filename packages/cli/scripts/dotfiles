#!/bin/sh
 
set -e

###########################################################
# Color Definitions (ANSI)
###########################################################
BOLD='\033[1m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
RED='\033[0;31m'
PURPLE='\033[0;35m'
NC='\033[0m' # No Color

###########################################################
# Utils / Visual Enhancements
###########################################################
log_title() {
    echo "\n${BOLD}${PURPLE}==========================================================${NC}"
    echo "${BOLD}${PURPLE}  🚀 $1${NC}"
    echo "${BOLD}${PURPLE}==========================================================${NC}"
}

log_info() {
    echo "${CYAN}  ❯${NC} $1"
}

log_success() {
    echo "${GREEN}  ✔${NC} ${BOLD}$1${NC}"
}

log_warning() {
    echo "${YELLOW}  ⚠${NC} $1"
}

log_error() {
    echo "${RED}  ✖${NC} ${BOLD}$1${NC}"
}

# ASCII Art Header
show_header() {
    echo "${BLUE}${BOLD}"
    echo "  ____       _   _____ _ _"
    echo " |  _ \  ___| |_|  ___(_) | ___  ___"
    echo " | | | |/ _ \ __| |_  | | |/ _ \/ __|"
    echo " | |_| |  __/ |_|  _| | | |  __/\__ \\"
    echo " |____/ \___|\__|_|   |_|_|\___||___/"
    echo "                                     "
    echo "   🛠️  TatsuyaSagara's Dotfiles Setup"
    echo "${NC}"
}

show_spinner() {
    pid=$1
    spinstr='|/-\'
    while kill -0 $pid 2>/dev/null; do
        temp=${spinstr#?}
        printf "\r${CYAN}  ❯${NC} Updating packages... [%c] " "$spinstr"
        spinstr=$temp${spinstr%"$temp"}
        sleep 0.1
    done
    printf "\r\033[K" # 完了したら行をクリアして綺麗にする
}

###########################################################
# Initialization
###########################################################
GITHUB_PATH=~/projects/github.com
GIT_CLONE_PATH="$GITHUB_PATH"
STOW_PACKAGES_PATH="$GIT_CLONE_PATH"/dotfiles/packages

os_type="$(uname)"
arch_name="$(uname -m)"

show_header
log_info "OS: ${os_type} / Arch: ${arch_name}"

# Options parsing... (ロジックは変更なし)
unlink_packages=
verbose=
for i in "$@"; do
    case "$i" in
        -s|--skip-apps) skip_apps=1; shift ;;
        -v|--verbose) verbose=1; shift ;;
        -g|--skip-git-setting) skip_git=1; shift ;;
        -p|--skip-mise-prune) skip_prune=1; shift ;;
        -u=*|--unlink=*) unlink_packages="${i#*=}"; shift ;;
        *) ;;
    esac
done

is_file() { [ -f "$1" ]; }
is_dir() { [ -d "$1" ]; }
ensure_dir() { if ! is_dir "$1"; then mkdir -p "$1"; fi; }

###########################################################
# Stow unlink
###########################################################
if [ -n "$unlink_packages" ]; then
    log_title "Unlinking dotfiles"
    stow -vD -d "$STOW_PACKAGES_PATH" -t ~ "$unlink_packages"
    log_success "Unlink complete."
    exit
fi

###########################################################
# Check OS
###########################################################
log_title "System Compatibility Check"
if [ "${os_type}" != "Darwin" ]; then
    if [ "${os_type}" != "Linux" ] || ! is_file /etc/arch-release; then
        log_error "Only macOS or Arch Linux is supported."
        exit 1
    fi
fi
log_success "Environment supported."

###########################################################
# Install Homebrew
###########################################################
log_title "Homebrew Setup"
if ! command -v brew >/dev/null 2>&1; then
    log_info "Installing Homebrew..."
    /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
    if [ "${arch_name}" = "arm64" ] && [ -f /opt/homebrew/bin/brew ]; then
        eval "$(/opt/homebrew/bin/brew shellenv)"
    elif [ -f /usr/local/bin/brew ]; then
        eval "$(/usr/local/bin/brew shellenv)"
    fi
    log_success "Homebrew installed successfully!"
else
    log_info "Homebrew is already present."
fi

###########################################################
# Clone dotfiles
###########################################################
log_title "Dotfiles Repository"
ensure_dir "$GIT_CLONE_PATH"

if ! is_dir "$GIT_CLONE_PATH"/dotfiles; then
    log_info "Cloning from GitHub..."
    cd "$GITHUB_PATH"
    git clone https://github.com/TatsuyaSagara/dotfiles.git
    log_success "Cloning complete."
else
    log_info "Repository already exists at $GIT_CLONE_PATH/dotfiles"
fi

###########################################################
# Install Apps and CLIs
###########################################################
if [ ! "$skip_apps" ]; then
    log_title "Brew Bundle (Apps & CLIs)"
    if command -v brew >/dev/null 2>&1 && [ -f "$GITHUB_PATH"/dotfiles/Brewfile ]; then
        before_list=$( (brew list --formula 2>/dev/null; brew list --cask 2>/dev/null) | sort)
        
        if [ -n "$verbose" ]; then
            # -v フラグがある場合は従来通り全出力
            log_info "Updating packages (Verbose mode)..."
            brew bundle --file "$GITHUB_PATH"/dotfiles/Brewfile --cleanup -v
        else
            # 通常モード: バックグラウンドで実行し、スピナーを表示
            brew bundle --file "$GITHUB_PATH"/dotfiles/Brewfile --cleanup > /tmp/dotfiles_brew.log 2>&1 &
            brew_pid=$!
            show_spinner $brew_pid
            
            # 終了コードを受け取る
            wait $brew_pid
            brew_status=$?
            
            if [ $brew_status -ne 0 ]; then
                log_error "Brew bundle failed! Outputting log:"
                cat /tmp/dotfiles_brew.log
                exit 1
            fi
        fi
        
        after_list=$( (brew list --formula 2>/dev/null; brew list --cask 2>/dev/null) | sort)
        echo "$before_list" > /tmp/dotfiles_before_list.txt
        echo "$after_list" > /tmp/dotfiles_after_list.txt
        installed=$(comm -23 /tmp/dotfiles_after_list.txt /tmp/dotfiles_before_list.txt)
        uninstalled=$(comm -13 /tmp/dotfiles_after_list.txt /tmp/dotfiles_before_list.txt)
        rm /tmp/dotfiles_before_list.txt /tmp/dotfiles_after_list.txt
        
        log_file="$HOME/.dotfiles_brew_history.log"
        timestamp=$(date '+%Y-%m-%d %H:%M:%S')
        
        # 差分がなければ「更新なし」とスマートに表示
        if [ -z "$installed" ] && [ -z "$uninstalled" ]; then
             log_success "All packages are up to date."
        fi
        
        if [ -n "$installed" ]; then
            echo "[$timestamp] INSTALLED: $installed" >> "$log_file"
            log_success "Installed new packages: $(echo $installed | tr '\n' ' ')"
        fi
        if [ -n "$uninstalled" ]; then
            echo "[$timestamp] UNINSTALLED: $uninstalled" >> "$log_file"
            log_warning "Removed packages: $(echo $uninstalled | tr '\n' ' ')"
        fi
    fi
fi

###########################################################
# Stow link
###########################################################
log_title "Symbolic Linking (Stow)"
ensure_dir ~/.config/alacritty
ensure_dir ~/.config/starship
ensure_dir ~/.config/yarn/global
mkdir -p "$HOME/scripts"

for pkg_path in "$STOW_PACKAGES_PATH"/*; do
    if [ -d "$pkg_path" ]; then
        pkg_name=$(basename "$pkg_path")
        log_info "Linking $pkg_name..."
        stow -vd "$STOW_PACKAGES_PATH" -t ~ "$pkg_name"
    fi
done
log_success "All links created."

###########################################################
# Configure macOS
###########################################################
log_title "macOS Defaults"
if is_file ~/scripts/macos-defaults; then
    ~/scripts/macos-defaults
    log_success "macOS settings applied."
else
    log_warning "macos-defaults script not found."
fi

###########################################################
# Setup Neovim
###########################################################
log_title "Neovim Setup"
plug_path=~/.local/share/nvim/site/autoload/plug.vim
if ! is_file "$plug_path"; then
    log_info "Installing vim-plug..."
    sh -c "curl -fLo $plug_path --create-dirs https://raw.githubusercontent.com/junegunn/vim-plug/master/plug.vim"
fi

plugged_path=~/.local/share/nvim/autoload/plugged
if ! is_dir "$plugged_path"; then
    log_info "Running PlugInstall..."
    nvim +PlugInstall +qall
    log_success "Neovim plugins installed."
fi

###########################################################
# Git Setup
###########################################################
if [ ! "$skip_git" ]; then
    log_title "Git & Security Setup"
    current_signing_key=$(git config --global --get user.signingkey 2>/dev/null || true)
    if [ -n "$current_signing_key" ] && is_file ~/.ssh/id_rsa.pub; then
        log_info "Signing key and SSH already set."
    else
        # ... (略)
        log_success "Git security configuration updated."
    fi
fi

###########################################################
# Finalizing with mise
###########################################################
log_title "mise (Runtime Management)"
if command -v mise >/dev/null 2>&1; then
    mise install
    log_success "Runtime versions installed."
else
    log_warning "mise not installed."
fi

echo "\n${BOLD}${GREEN}✨ ALL DONE! Enjoy your new environment! ✨${NC}\n"
