#!/bin/sh
 
set -e

GITHUB_PATH=~/projects/github.com
GIT_CLONE_PATH="$GITHUB_PATH"
STOW_PACKAGES_PATH="$GIT_CLONE_PATH"/dotfiles/packages
#STOW_PACKAGES_PATH="$GITHUB_PATH"/dotfiles/packages

os_type="$(uname)"  # ex) Darwin / Linux
arch_name="$(uname -m)" # ex) x86_64 / arm64

###########################################################
# Options
###########################################################
unlink_packages=
verbose=
for i in "$@"; do
    case "$i" in
        -s|--skip-apps)
            skip_apps=1
            shift ;;
        -v|--verbose)
            verbose=1
            shift ;;
        -g|--skip-git-setting)
            skip_git=1
            shift ;;
        -p|--skip-mise-prune)
            skip_prune=1
            shift ;;
        -u=*|--unlink=*)
            unlink_packages="${i#*=}"
            shift ;;
        *) ;;
    esac
done

###########################################################
# Utils
###########################################################
log() {
    message=$1
    echo "📌$message"
}

log_warning() {
    message=$1
    echo "$message"
}

is_file() {
    path="$1"
    [ -f "$path" ]
}

is_dir() {
    path="$1"
    [ -d "$path" ]
}

ensure_dir() {
    path="$1"
    if ! is_dir "$path"; then
        mkdir -p "$path"
    fi
}

log "Start dotfiles => ${os_type}/${arch_name}"

###########################################################
# Stow unlink
###########################################################
if [ -n "$unlink_packages" ]; then
    log 'Unlinking dotfiles...'
    stow -vD -d "$STOW_PACKAGES_PATH" -t ~ "$unlink_packages"
    exit
fi

###########################################################
# Check operating system or distribution
###########################################################
if [ "${os_type}" != "Darwin" ]; then
    if [ "${os_type}" != "Linux" ] || ! is_file /etc/arch-release; then
        log 'Supported is macOS or Arch Linux only...'
        exit 1
    fi
fi
log 'Check for supported OS ...OK'

###########################################################
# Install Homebrew
###########################################################
if ! command -v brew >/dev/null 2>&1; then
    log 'Homebrew not found. Installing...'
    /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
    if [ "${arch_name}" = "arm64" ] && [ -f /opt/homebrew/bin/brew ]; then
        eval "$(/opt/homebrew/bin/brew shellenv)"
    elif [ -f /usr/local/bin/brew ]; then
        eval "$(/usr/local/bin/brew shellenv)"
    fi
    log '=====> Install Homebrew SUCCESS'
else
    log 'Homebrew already installed'
fi

###########################################################
# Clone dotfiles
###########################################################
ensure_dir "$GIT_CLONE_PATH"

if ! is_dir "$GIT_CLONE_PATH"/dotfiles; then
    log 'Clone dotfiles'
    cd "$GITHUB_PATH"
    git clone https://github.com/TatsuyaSagara/dotfiles.git
fi

###########################################################
# Install Apps and CLIs
###########################################################
if [ ! "$skip_apps" ]; then
    log 'Install Apps and CLIs'
    if command -v brew >/dev/null 2>&1 && [ -f "$GITHUB_PATH"/dotfiles/Brewfile ]; then
        # Record current installed formulas before bundle
        before_list=$(brew list --formula 2>/dev/null | sort)
        brew bundle --file "$GITHUB_PATH"/dotfiles/Brewfile --cleanup $([ -n "$verbose" ] && echo -v)
        # Record installed formulas after bundle
        after_list=$(brew list --formula 2>/dev/null | sort)
        # Determine installed and uninstalled using temporary files for POSIX compatibility
        echo "$before_list" > /tmp/dotfiles_before_list.txt
        echo "$after_list" > /tmp/dotfiles_after_list.txt
        installed=$(comm -23 /tmp/dotfiles_after_list.txt /tmp/dotfiles_before_list.txt)
        uninstalled=$(comm -13 /tmp/dotfiles_after_list.txt /tmp/dotfiles_before_list.txt)
        rm /tmp/dotfiles_before_list.txt /tmp/dotfiles_after_list.txt
        # Log changes
        log_file="$HOME/.dotfiles_brew_history.log"
        timestamp=$(date '+%Y-%m-%d %H:%M:%S')
        if [ -n "$installed" ]; then
            echo "[$timestamp] INSTALLED: $installed" >> "$log_file"
        fi
        if [ -n "$uninstalled" ]; then
            echo "[$timestamp] UNINSTALLED: $uninstalled" >> "$log_file"
        fi
    else
        log 'Brewfile or Homebrew not found, skipping brew bundle'
    fi
fi

###########################################################
# Stow link
###########################################################
log 'Stow link'
ensure_dir ~/.config/alacritty
ensure_dir ~/.config/starship
ensure_dir ~/.config/yarn/global

mkdir -p "$HOME/scripts"
for pkg_path in "$STOW_PACKAGES_PATH"/*; do
    if [ -d "$pkg_path" ]; then
        stow -vd "$STOW_PACKAGES_PATH" -t ~ "$(basename "$pkg_path")"
    fi
done

###########################################################
# Configure macOS setting
###########################################################
log 'Configuring macOS default settings'
~/scripts/macos-defaults

###########################################################
# Setup Neovim
###########################################################
log 'Setup Neovim'
plug_path=~/.local/share/nvim/site/autoload/plug.vim
if ! is_file "$plug_path"; then
    sh -c "curl -fLo $plug_path --create-dirs https://raw.githubusercontent.com/junegunn/vim-plug/master/plug.vim"
fi

plugged_path=~/.local/share/nvim/autoload/plugged
if ! is_dir "$plugged_path"; then
    nvim +PlugInstall +qall
    log '=====> Setup Neovim SUCCESS'
fi

###########################################################
# Setup pynvim
###########################################################
log 'Setup pynvim'
if command -v pipx >/dev/null 2>&1; then
    if ! pipx list 2>/dev/null | grep -qE '^[[:space:]]*pynvim'; then
        pipx install pynvim
    else
        log 'pynvim already installed via pipx'
    fi
else
    log 'pipx not installed; skipping pynvim setup'
fi

###########################################################
# Setup pipx PATH
###########################################################
if command -v pipx >/dev/null 2>&1; then
    pipx ensurepath >/dev/null 2>&1 || true
fi

###########################################################
# Setup Git
###########################################################
if [ ! "$skip_git" ]; then
    current_signing_key=$(git config --global --get user.signingkey 2>/dev/null || true)
    if [ -n "$current_signing_key" ] && is_file ~/.ssh/id_rsa.pub; then
        log 'Git signing key and SSH key already configured; skipping git setup'
    else
        if ! is_dir ~/.gnupg || [ -z "$(gpg --list-secret-keys --with-colons | awk -F: '/^sec:/ {print $5; exit}')" ]; then
            log 'Install gpg signing with git'
            gpg --default-new-key-algo rsa4096 --gen-key
        fi

        key_id=$(gpg --list-secret-keys --with-colons | awk -F: '/^sec:/ {print $5; exit}')
        if [ -n "$key_id" ]; then
            log 'Copy and paste the GPG key below to GitHub'
            gpg --armor --export "$key_id"
            git config --global user.signingkey "$key_id"
        fi

        if ! is_file ~/.ssh/id_rsa.pub; then
            log 'Setup SSH key for git'
            ssh-keygen -t rsa -b 4096 -C "tatsuya.sagara@icloud.com"
            log 'Copy and paste the SSH key below to GitHub'
            cat ~/.ssh/id_rsa.pub
        fi
        log '=====> Setup Git SUCCESS'
    fi
fi

####################t######################################
# mise
###########################################################
log 'mise'
if command -v mise >/dev/null 2>&1; then
    if [ ! "$skip_apps" ]; then
        mise install
        if [ ! "$skip_prune" ]; then
            mise prune -y
        fi
    fi
    mise list
else
    log 'mise not installed; skipping mise commands'
fi

###########################################################
# Setup Yarn global
###########################################################
if ! command -v yarn >/dev/null 2>&1; then
  # https://qiita.com/iisaka51/items/845b39cdaa210cf6d31e#rtx-activateは何をするのでしょうか
  mise x -- npm install -g yarn
  log '=====> Setup Yarn global SUCCESS'
fi
